@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 border p-4 shadow-sm rounded bg-light">
            <h2 class="title">CinemaBaby</h2>
            <hr />

            <form asp-action="Login" asp-controller="Account" method="post">
                <div class="form-group mb-3">
                    <label class="fw-bold">Tên đăng nhập</label>
                    <input name="username" class="form-control" placeholder="Nhập username..." required />
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold">Mật khẩu</label>
                    <input name="password" type="password" class="form-control" placeholder="Nhập mật khẩu..." required />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Đăng Nhập</button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    @ViewBag.Error
                </div>
            }

            <div class="mt-3 text-center">
                <small>Chưa có tài khoản? <a asp-action="Register" asp-controller="Account">Đăng ký ngay</a></small>
            </div>
        </div>
    </div>
</div>