@model CinemaBaby.Models.Customer

@{
    ViewData["Title"] = "Đăng ký thành viên";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 border p-4 shadow-sm rounded bg-light">
            <h3 class="text-center text-success mb-4">ĐĂNG KÝ THÀNH VIÊN</h3>
            <hr />

            <form asp-action="Register" asp-controller="Account" method="post">
                <div class="mb-3">
                    <label class="fw-bold">Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control" placeholder="Chọn tên đăng nhập..." required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="fw-bold">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu..." required />
                </div>

                <div class="mb-3">
                    <label class="fw-bold">Họ và Tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập tên của bạn..." />
                </div>

                <div class="mb-3">
                    <label class="fw-bold">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="ví dụ: email@gmail.com" />
                </div>

                <button type="submit" class="btn btn-success w-100 py-2">Tạo Tài Khoản</button>
            </form>

            <div class="mt-3 text-center">
                <small>Đã có tài khoản? <a asp-action="Login" asp-controller="Account">Đăng nhập tại đây</a></small>
            </div>
        </div>
    </div>
</div>