@model CinemaBaby.Models.Promotion

<h2>➕ Thêm khuyến mãi</h2>

<form asp-action="Create" method="post">

    <input asp-for="Title" class="form-control mb-2" placeholder="Tiêu đề" />

    <textarea asp-for="Description" class="form-control mb-2" placeholder="Mô tả"></textarea>

    <input asp-for="ImageUrl" class="form-control mb-2" placeholder="Link ảnh" />

    <input asp-for="StartDate" type="date" class="form-control mb-2" />

    <input asp-for="EndDate" type="date" class="form-control mb-2" />

    <button class="btn btn-primary">Lưu</button>

</form>