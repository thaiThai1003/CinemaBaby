@model CinemaBaby.Models.Movie

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 border p-4 shadow-sm rounded bg-white">

            <h2 class="text-success text-center">➕ THÊM PHIM MỚI</h2>
            <hr />

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- Tên phim -->
                <div class="mb-3">
                    <label class="fw-bold">Tên phim</label>
                    <input asp-for="Title" class="form-control" required />
                </div>

                <!-- Thể loại -->
                <div class="mb-3">
                    <label class="fw-bold">Thể loại</label>
                    <input asp-for="Genre" class="form-control" />
                </div>

                <!-- Thời lượng + ngày -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Thời lượng (phút)</label>
                        <input asp-for="Duration" type="number" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Ngày chiếu</label>
                        <input asp-for="ReleaseDate" type="date" class="form-control" />
                    </div>
                </div>

                <!-- Poster -->
                <div class="mb-3">
                    <label class="fw-bold">Link ảnh Poster</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="Dán link ảnh vào đây..." />
                </div>

                <!-- Trailer -->
                <div class="mb-3">
                    <label class="fw-bold">Link Trailer (YouTube)</label>
                    <input asp-for="TrailerUrl" class="form-control" placeholder="https://www.youtube.com/watch?v=..." />
                </div>

                <!-- Button -->
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success">💾 Lưu phim</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">↩ Quay lại</a>
                </div>

            </form>
        </div>
    </div>
</div>